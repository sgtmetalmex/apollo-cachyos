--- a/src/process.cpp
+++ b/src/process.cpp
@@ -197,9 +197,19 @@
     uint32_t render_width = client_width;
     uint32_t render_height = client_height;
 
+    // Resolve effective scale_factor in priority order:
+    //   1. Per-app config (apps.json scale-factor != 100)  — explicit per-game
+    //   2. Client-requested (launch_session->scale_factor != 100) — from URL arg
+    //   3. Host-side default (config::video.default_scale_factor) — global, set in sunshine.conf
+    //   4. 100 (no scaling)
     int scale_factor = launch_session->scale_factor;
     if (_app.scale_factor != 100) {
       scale_factor = _app.scale_factor;
+    } else if (scale_factor == 100 && config::video.default_scale_factor != 100) {
+      // Neither client nor per-app overrode; fall back to the global default.
+      // The user sets this ONCE in sunshine.conf (default_scale_factor = 150)
+      // and it applies to every game automatically.
+      scale_factor = config::video.default_scale_factor;
     }
 
