   void closeVDisplayDevice() {
+    // Tell the EVDI event pump to exit first; join *outside* the
+    // vdisplay_mutex so we don't deadlock against the loop's lock acquire.
+    if (evdi_events_running) {
+      evdi_events_running = false;
+      if (evdi_events_thread.joinable()) {
+        evdi_events_thread.join();
+      }
+      BOOST_LOG(info) << "[VDISPLAY] EVDI event pump thread stopped.";
+    }
+
