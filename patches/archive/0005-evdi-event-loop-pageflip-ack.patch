@@ -1026,6 +1142,33 @@
           // surface a new "DVI-I-1" output for kscreen-doctor to find.
           // vdinfo.drm_fd stays at -1 (initialized at start of this function).
 
+          // Register a CPU buffer with libevdi and arm the first update. The
+          // global evdi_events_loop will then service pageflip ACKs as kwin
+          // submits frames. Without this kwin times out every pageflip and
+          // stops drawing — Apollo's KMS capture would then read zeros.
+          // We don't actually consume the pixels from this buffer; the
+          // existing KMS capture pipeline reads kwin's GBM-allocated dma-buf
+          // via drmPrimeHandleToFD. The buffer just gives the kernel a place
+          // to write so update_ready events fire.
+          {
+            const size_t stride = static_cast<size_t>(width) * 4;
+            vdinfo.evdi_buf.assign(stride * height, 0);
+            evdi_buffer ebuf {};
+            ebuf.id = 1;
+            ebuf.buffer = vdinfo.evdi_buf.data();
+            ebuf.width = static_cast<int>(width);
+            ebuf.height = static_cast<int>(height);
+            ebuf.stride = static_cast<int>(stride);
+            ebuf.rects = nullptr;
+            ebuf.rect_count = 0;
+            evdi.register_buffer(handle, ebuf);
+            vdinfo.evdi_buf_id = ebuf.id;
+            evdi.request_update(handle, vdinfo.evdi_buf_id);
+            BOOST_LOG(info) << "[VDISPLAY] Registered libevdi buffer id=" << vdinfo.evdi_buf_id
+                            << " (" << width << "x" << height << ", " << vdinfo.evdi_buf.size()
+                            << " bytes); pageflips will now complete.";
+          }
+
           BOOST_LOG(info) << "[VDISPLAY] Created EVDI virtual display on device " << device;
 
           // Ask KDE to actually USE the new output. Without this kwin leaves
@@ -1069,6 +1212,13 @@
     BOOST_LOG(info) << "[VDISPLAY] Removing virtual display: " << vdinfo.name;
 
     if (vdinfo.using_evdi && vdinfo.handle) {
+      // Unregister the libevdi buffer before closing so the kernel doesn't
+      // try to write into freed memory (vdinfo.evdi_buf is destroyed when the
+      // map entry is erased below).
+      if (vdinfo.evdi_buf_id > 0) {
+        evdi.unregister_buffer(vdinfo.handle, vdinfo.evdi_buf_id);
+        vdinfo.evdi_buf_id = 0;
+      }
       evdi.disconnect(vdinfo.handle);
       evdi.close(vdinfo.handle);
       kscreen::on_evdi_removed();
