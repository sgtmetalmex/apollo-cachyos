+  // Global libevdi event-loop thread. One per process, services every active
+  // VirtualDisplayInfo. Drains evdi_handle_events and re-arms evdi_request_update
+  // so kwin's DRM pageflips actually complete.
+  static std::atomic<bool> evdi_events_running {false};
+  static std::thread evdi_events_thread;
