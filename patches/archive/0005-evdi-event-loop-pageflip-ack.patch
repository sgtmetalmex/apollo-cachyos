@@ -830,6 +845,89 @@
   // Public API Implementation
   // ============================================================================
 
+  // Drive libevdi's event pump for every active EVDI virtual display.
+  //
+  // The kernel-side contract (from evdi_painter.c):
+  //   1. kwin issues drmModeAtomicCommit (a pageflip) on the EVDI card.
+  //   2. evdi kernel sees is_connected=true and num_dirts>0, so it QUEUES the
+  //      pending vblank event instead of sending it to kwin immediately.
+  //   3. evdi kernel emits an update_ready event on the libevdi fd.
+  //   4. We must call evdi_handle_events to dispatch, AND evdi_grab_pixels
+  //      to actually drain the dirty rects — the kernel only releases the
+  //      queued vblank inside the GRAB_PIXELS ioctl (see line 1185 of
+  //      evdi_painter.c: `evdi_send_vblank(crtc, vblank)` after the copy).
+  //   5. kwin's pageflip then completes and kwin can submit the next frame.
+  //
+  // Without step 4 (the previous version of this patch), kwin's pageflips
+  // stayed queued indefinitely — observable as "Pageflip timed out! This is
+  // a bug in the evdi kernel driver" every ~1s in kwin_wayland's log, kwin
+  // stalling on rendering, and Apollo's KMS capture reading stale pixels.
+  static void evdi_events_loop() {
+    evdi_event_context ctx {};
+    // No-op update handler: we don't *use* the pixels (Apollo's KMS capture
+    // reads kwin's GBM-backed dma-buf via drmPrimeHandleToFD separately).
+    // We still call grab_pixels below to release the kernel's queued vblank.
+    ctx.update_ready_handler = [](int /*buffer_id*/, void * /*user_data*/) {};
+    ctx.user_data = nullptr;
+
+    // Reusable scratch buffer for the dirty-rect dance. evdi_grab_pixels
+    // wants somewhere to copy the rect list; we don't care about the contents.
+    constexpr int MAX_RECTS = 16;
+    evdi_rect rects[MAX_RECTS];
+
+    while (evdi_events_running) {
+      // Snapshot active EVDI handles + buf_ids under the lock; release before
+      // calling into libevdi so a slow handle_events doesn't block
+      // createVirtualDisplay / removeVirtualDisplay.
+      struct entry_t {
+        evdi_handle handle;
+        int buf_id;
+      };
+      std::vector<entry_t> active;
+      {
+        std::lock_guard<std::mutex> lock(vdisplay_mutex);
+        active.reserve(virtual_displays.size());
+        for (auto &[guid, vdinfo] : virtual_displays) {
+          if (vdinfo.using_evdi && vdinfo.handle) {
+            active.push_back({vdinfo.handle, vdinfo.evdi_buf_id});
+          }
+        }
+      }
+
+      for (const auto &e : active) {
+        // evdi_get_event_ready returns evdi_selectable (which is just `int`,
+        // a file descriptor). Apollo doesn't pull in <evdi_lib.h> so we
+        // use plain int.
+        const int fd = evdi.get_event_ready(e.handle);
+        if (fd < 0) {
+          continue;
+        }
+        // Non-blocking check: are there pending events on this fd?
+        struct pollfd pfd {};
+        pfd.fd = fd;
+        pfd.events = POLLIN;
+        int pr = ::poll(&pfd, 1, 0);
+        if (pr > 0 && (pfd.revents & POLLIN)) {
+          // Dispatch update_ready (no-op callback) so libevdi advances state.
+          evdi.handle_events(e.handle, &ctx);
+          // Drain the dirty rectangles. This is the ioctl that releases the
+          // queued vblank inside the kernel, allowing kwin's pageflip to
+          // complete. num_rects is in/out: pass capacity, get filled count.
+          int num_rects = MAX_RECTS;
+          evdi.grab_pixels(e.handle, rects, &num_rects);
+        }
+        // Always (re)arm the next update request. This is cheap — the kernel
+        // either marks was_update_requested or returns immediately if pixels
+        // are already pending. Safe to call repeatedly.
+        if (e.buf_id > 0) {
+          evdi.request_update(e.handle, e.buf_id);
+        }
+      }
+
+      usleep(2000);  // 2ms — under half a 240Hz frame, low CPU.
+    }
+  }
+
   DRIVER_STATUS openVDisplayDevice() {
     std::lock_guard<std::mutex> lock(vdisplay_mutex);
 
