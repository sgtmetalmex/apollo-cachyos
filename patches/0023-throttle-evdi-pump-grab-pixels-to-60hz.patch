+    // if higher client rates are needed in the future, plumb the
+    // configured fps through to here.
+    constexpr int64_t MIN_GRAB_PERIOD_US = 16667;  // 1_000_000 / 60
+    std::map<evdi_handle, std::chrono::steady_clock::time_point> last_grab_at;
