+  // Without this loop, kwin spams "Pageflip timed out!" every ~1s, stops
+  // rendering, and Apollo's capture sees only the zero-initialised buffer.
+  static void evdi_events_loop() {
+    evdi_event_context ctx {};
+    ctx.update_ready_handler = [](int /*buffer_id*/, void * /*user_data*/) {
+      // No-op: we drain pixels below via evdi_grab_pixels regardless.
+    };
+    ctx.user_data = nullptr;
+
+    constexpr int MAX_RECTS = 16;
+    evdi_rect rects[MAX_RECTS];
+
+    while (evdi_events_running) {
+      // Snapshot active EVDI handles + buf_ids + buffers under the lock,
+      // release before calling into libevdi.
+      struct entry_t {
+        evdi_handle handle;
+        int buf_id;
+        std::shared_ptr<EvdiBuffer> buffer;
+      };
+      std::vector<entry_t> active;
+      {
+        std::lock_guard<std::mutex> lock(vdisplay_mutex);
+        active.reserve(virtual_displays.size());
