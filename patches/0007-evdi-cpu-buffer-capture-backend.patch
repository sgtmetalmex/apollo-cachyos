+            active.push_back({vdinfo.handle, vdinfo.evdi_buf_id, vdinfo.evdi_buf});
+          }
+        }
+      }
+
+      for (const auto &e : active) {
+        const int fd = evdi.get_event_ready(e.handle);
+        if (fd < 0) {
